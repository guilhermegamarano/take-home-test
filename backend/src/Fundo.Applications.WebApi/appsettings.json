{
  "ConnectionStrings": {
    "LoansDatabase": ""
  },
  "Authentication": {
    "Issuer": "Fundo.Loans.Api",
    "Audience": "Fundo.Loans.Client",
    "SigningKey": "",
    "Username": "",
    "Password": "",
    "ReadOnlyUsername": "",
    "ReadOnlyPassword": "",
    "TokenLifetimeMinutes": 30
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "RateLimiting": {
    "WritePermitLimit": 30
  },
  "LoanProducts": {
    "DefaultType": "personal",
    "Products": [
      {
        "Type": "personal",
        "MinimumAmount": 500.00,
        "MaximumAmount": 25000.00,
        "MinimumPayment": 25.00,
        "Enabled": true
      },
      {
        "Type": "small-business",
        "MinimumAmount": 10000.00,
        "MaximumAmount": 250000.00,
        "MinimumPayment": 100.00,
        "Enabled": true
      },
      {
        "Type": "bridge",
        "MinimumAmount": 50000.00,
        "MaximumAmount": 1000000.00,
        "MinimumPayment": 500.00,
        "Enabled": true
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
      "FormatterName": "json"
    }
  },
  "AllowedHosts": "*"
}
